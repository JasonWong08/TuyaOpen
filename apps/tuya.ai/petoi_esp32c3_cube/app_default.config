CONFIG_PROJECT_VERSION="1.0.0"
CONFIG_TUYA_PRODUCT_ID="xlq6xkhdgvx0d0rl"
# Audio-first stabilization:
# disable display stack by default on ESP32-C3 to avoid LVGL assert/reboot loop.
# Re-enable later after audio path is proven stable.
# CONFIG_ENABLE_COMP_AI_DISPLAY is not set
CONFIG_BOARD_CHOICE_ESP32=y
CONFIG_BOARD_CHOICE_PETOI_ESP32C3_CUBE=y
CONFIG_ENABLE_BUTTON=y
CONFIG_BUTTON_NAME="ai_chat_button"

# --- ESP32-C3 memory budget (no PSRAM, ~85 KB free after net/BLE init) ---
#
# Default values and their impact on heap:
#   AI_INPUT_RINGBUF   64 KB  → 8 KB   (streaming input from mic to AI agent)
#   AI_OUTPUT_RINGBUF  64 KB  → 8 KB   (streaming output from AI agent)
#   AI_PLAYER_RINGBUF  16 KB  → 2 KB   (must fit largest free block ~2.3KB at bind)
#   AI_PLAYER_DECODEBUF 8 KB  → 2 KB   (decoder working buffer)
#   AI_PLAYER_FRAMEBUF  4 KB  → 2 KB   (single decode frame)
#   AI_PLAYER_STACK     2 KB  → 6 KB  (2048 B was too small: ai_player stack canary fault with MP3 decode)
#   AI_WRITE_SOCKET     8 KB  → 4 KB   (WebSocket send buffer)
#   AI_AUDIO_VAD_ACTIVE_MS 200 ms → 0  (recording ringbuf 16001 B → 9601 B)
#   LVGL task stack        8 KB  → 4 KB (simple chatbot UI needs no more)
#   LVGL double-start bug  fixed  (was creating 2nd 8 KB task + semaphores)
#
# Total saved (this round): ~10 KB (LVGL bug) + 4 KB (stack) + 6.4 KB (VAD) = ~20 KB
# Further trim streaming buffers so AI MQTT + TLS + session setup keeps ~28KB+
# free heap headroom on C3 (avoids perpetual defer / stalled cloud path).
CONFIG_AI_INPUT_RINGBUF_SIZE=1536
CONFIG_AI_OUTPUT_RINGBUF_SIZE=1024
CONFIG_AI_INPUT_BUF_SIZE=1024
CONFIG_AI_OUTPUT_BUF_SIZE=1024
CONFIG_AI_INPUT_STACK_SIZE=2560
CONFIG_AI_OUTPUT_STACK_SIZE=2560
CONFIG_AI_CLIENT_STACK_SIZE=2560
# Ringbuf 须 < Phase-4 后 typical largest_block（~2.3KB），否则 datasink_mem 创建失败
CONFIG_AI_PLAYER_RINGBUF_SIZE=2048
CONFIG_AI_PLAYER_DECODEBUF_SIZE=2048
CONFIG_AI_PLAYER_FRAMEBUF_SIZE=2048
CONFIG_AI_PLAYER_STACK_SIZE=6144
CONFIG_AI_WRITE_SOCKET_BUF_SIZE=2048
CONFIG_AI_AUDIO_VAD_ACTIVE_MS=0
#
# AI protocol context allocates one large static recv buffer sized by
# AI_MAX_FRAGMENT_LENGTH. On ESP32-C3, 10KB default often exceeds largest
# free block after MQTT+audio startup and causes ai_basic_proto init failure.
CONFIG_AI_MAX_FRAGMENT_LENGTH=1024

# Cloud-first on ESP32-C3: disable non-essential heavy modules during
# stabilization to keep TLS handshake memory headroom.
# Force smaller TLS fragment buffers (libtls default on RTOS is 10KB each,
# which is too expensive for ESP32-C3 no-PSRAM during WiFi/BLE + TLS overlap).
# Keep TLS content length below 4KB to reduce peak handshake heap,
# while avoiding the 2KB setting that previously caused MQTT TLS failures.
CONFIG_ENABLE_MBEDTLS_SSL_MAX_CONTENT_LEN=3072
CONFIG_ENABLE_COMP_AI_VIDEO=n
CONFIG_ENABLE_COMP_AI_MCP=n
CONFIG_ENABLE_COMP_AI_PICTURE=n
# AI monitor is a debug feature and creates extra socket/thread pressure.
# On ESP32-C3 no-PSRAM it can drive heap to near-zero after ai_agent_init.
# CONFIG_ENABLE_AI_MONITOR is not set

# Keep partition table / flash-size consistent for PETOI_ESP32C3_CUBE.
# CONFIG_ESPTOOLPY_FLASHSIZE_4MB is not set
CONFIG_ESPTOOLPY_FLASHSIZE_16MB=y
CONFIG_ESPTOOLPY_FLASHSIZE="16MB"
CONFIG_MBEDTLS_HKDF_C=y

# Keep icon/text font choices explicit for deterministic UI rendering.
CONFIG_ENABLE_AI_UI_ICON_FONT=y
CONFIG_FONT_TEXT_SIZE_18_2=y
CONFIG_FONT_ICON_SIZE_16_4=y

# Emoji font: 32 px instead of default 64 px.
# 64 px RGB565A8 glyph draw-buf = 64x64x3 = 12 KB > heap headroom (~9.5 KB).
# 32 px draw-buf = 32x32x3 = 3 KB, fits comfortably inside LV_DRAW_LAYER_SIMPLE_BUF_SIZE=4KB.
CONFIG_FONT_EMOJI_SIZE_32=y
# CONFIG_FONT_EMOJI_SIZE_64 is not set

# Force low-memory WiFi/BLE pool settings on ESP32-C3.
# Slightly smaller WiFi pools to leave headroom for concurrent HTTPS (meta.save) + AI path.
# Set both new(ESP_WIFI_*) and legacy(ESP32_WIFI_*) keys to guarantee
# the value is honored across different ESP-IDF/Kconfig alias paths.
CONFIG_ESP_WIFI_DYNAMIC_RX_BUFFER_NUM=8
CONFIG_ESP_WIFI_DYNAMIC_TX_BUFFER_NUM=8
CONFIG_ESP_WIFI_MGMT_SBUF_NUM=16
CONFIG_ESP32_WIFI_DYNAMIC_RX_BUFFER_NUM=8
CONFIG_ESP32_WIFI_DYNAMIC_TX_BUFFER_NUM=8
CONFIG_ESP32_WIFI_MGMT_SBUF_NUM=16
CONFIG_BTDM_BLE_ADV_REPORT_FLOW_CTRL_NUM=40
CONFIG_BTDM_SCAN_DUPL_CACHE_SIZE=40
